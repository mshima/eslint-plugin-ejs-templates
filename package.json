{
  "name": "eslint-plugin-ejs-templates",
  "version": "0.4.0",
  "description": "ESLint plugin for EJS (Embedded JavaScript) templates — processor and rules",
  "keywords": [
    "eslint",
    "eslint-plugin",
    "ejs",
    "template",
    "processor"
  ],
  "homepage": "https://github.com/mshima/eslint-plugin-ejs-templates#readme",
  "bugs": {
    "url": "https://github.com/mshima/eslint-plugin-ejs-templates/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mshima/eslint-plugin-ejs-templates.git"
  },
  "license": "Apache-2.0",
  "author": "",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "types": "dist/index.d.ts",
  "files": [
    "web-tree-sitter.d.ts",
    "dist",
    "wasm",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "fix": "prettier . --write && eslint . --fix",
    "lint": "eslint .",
    "prepare": "npm run build && cpy node_modules/tree-sitter-embedded-template/tree-sitter-embedded_template.wasm node_modules/tree-sitter-javascript/tree-sitter-javascript.wasm wasm --flat",
    "prepublishOnly": "npm run prepare",
    "pretest": "prettier . --check && eslint .",
    "test": "vitest run",
    "posttest": "npm run typecheck",
    "typecheck": "tsc -p tsconfig.spec.json --noEmit"
  },
  "dependencies": {
    "debug": "^4.4.3",
    "web-tree-sitter": "^0.26.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/debug": "^4.1.13",
    "@types/emscripten": "^1.41.5",
    "@types/node": "^25.5.0",
    "cpy-cli": "^7.0.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "prettier-plugin-packagejson": "^3.0.2",
    "tree-sitter-embedded-template": "0.25.0",
    "tree-sitter-javascript": "0.25.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "eslint": ">=9.0.0"
  }
}
